# EmailJS (https://www.emailjs.com) — required for the contact form.
# Without these the form falls back to opening the user's mail client.
VITE_EMAIL_SERVICE_ID=
VITE_EMAIL_TEMPLATE_ID=
VITE_EMAIL_PUBLIC_KEY=

# GitHub Pages base path. Must start AND end with "/".
# Default matches the upstream repo; change when forking.
VITE_BASE_PATH=/GAMEDEV_PORTFOLIO/

# Public origin + base (no trailing slash). Used for sitemap, canonical, OG.
VITE_SITE_URL=https://github.com/ABIKARTHICKGDEV/GAMEDEV_PORTFOLIO
